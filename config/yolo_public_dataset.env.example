# Copy this file to config/yolo_public_dataset.env before local training.
# config/*.env is ignored by Git so API keys and local paths stay private.

# Primary public fridge-like object-detection dataset.
# Roboflow Universe page:
# https://universe.roboflow.com/fridge-dataset/fridge-food-images
ROBOFLOW_DATASET_ID=fridge-dataset/fridge-food-images/14
ROBOFLOW_DATASET_URL=https://universe.roboflow.com/fridge-dataset/fridge-food-images

# YOLO11 export is preferred. If your Roboflow account cannot export yolov11,
# the download script falls back to yolov8, which Ultralytics YOLO11 can train on.
ROBOFLOW_FORMAT=yolov11
YOLO_DATASET_DIR=data/fridge-food-images

# Roboflow programmatic downloads normally require an API key.
# Do not commit the copied env file.
# ROBOFLOW_API_KEY=replace_me

# Local training defaults for this Mac.
YOLO_TRAIN_VENV=.venv-yolo
YOLO_PYTHON_VERSION=3.12
YOLO_MODEL=yolo11n.pt
YOLO_DATA_YAML=data/fridge-food-images/data.yaml
YOLO_IMG_SIZE=640
YOLO_EPOCHS=80
YOLO_BATCH=8
YOLO_WORKERS=4
YOLO_DEVICE=auto
YOLO_CACHE=False
YOLO_PATIENCE=20
YOLO_PROJECT=runs/fridge-yolo11n
YOLO_RUN_NAME=public-fridge-food-images

# Export/deploy defaults.
YOLO_EXPORT_MODEL=models/fridge-yolo11n.onnx
YOLO_EXPORT_LABELS=models/fridge-yolo11n.classes.txt
YOLO_REMOTE_HOST=firecar-pi
YOLO_REMOTE_DIR=~/yolo-inference
YOLO_REMOTE_MODEL_NAME=fridge-yolo11n.onnx
